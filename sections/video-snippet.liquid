<section class="video-snippet" aria-labelledby="video-snippet__title-{{ section.id }}">
  <div class="layout__grid-box">
    <div class="video-snippet__header">
      {% if section.settings.chip_text != blank %}
        <span class="video-snippet__chip">{{ section.settings.chip_text }}</span>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 id="video-snippet__title-{{ section.id }}" class="video-snippet__title">
          {{ section.settings.title }}
        </h2>
      {% endif %}
    </div>

    <div
      class="video-snippet__videos"
      data-video-snippet
    >
      {% for block in section.blocks %}
        <div class="video-snippet__video" {{ block.shopify_attributes }}>
          {% if block.settings.video != blank %}
            {{
              block.settings.video
              | video_tag:
                image_size: '800x',
                autoplay: true,
                loop: true,
                controls: false,
                muted: true,
                playsinline: true
            }}
          {% elsif block.settings.image != blank %}
            <img
              class="video-snippet__poster"
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.image.alt | escape }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              loading="lazy"
              decoding="async"
            >
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
  (function () {
    const root = document.currentScript.previousElementSibling;
    const container = root && root.querySelector('[data-video-snippet]');
    if (!container) return;
    const videos = container.querySelectorAll('video');
    if (!videos.length || !('IntersectionObserver' in window)) return;

    function pauseOffscreen(videoEls) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        videoEls.forEach((v) => v.pause());
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const p = entry.target.play();
              if (p && typeof p.catch === 'function') p.catch(() => {});
            } else {
              entry.target.pause();
            }
          });
        },
        { threshold: 0.25 }
      );
      videoEls.forEach((v) => io.observe(v));
    }

    pauseOffscreen(videos);
  })();
</script>

{% schema %}
{
  "name": "Video Snippet",
  "settings": [
    {
      "id": "chip_text",
      "type": "text",
      "label": "Chip Text",
      "default": "About Our Store"
    },
    {
      "id": "title",
      "type": "text",
      "label": "Title",
      "default": "BY FOOD VLOGGERS"
    }
  ],
  "blocks": [
    {
      "type": "video_block",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Shopify-hosted video",
          "info": "Optional. If empty, the image below will be shown instead."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Poster / fallback image",
          "info": "Used as the video poster, and shown if no video is uploaded."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Video Snippet",
      "category": "Videos",
      "blocks": [
        { "type": "video_block" },
        { "type": "video_block" },
        { "type": "video_block" },
        { "type": "video_block" }
      ]
    }
  ]
}
{% endschema %}
